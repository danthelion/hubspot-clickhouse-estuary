# Copy to .env (gitignored) and fill in real values.

# Your ngrok personal authtoken from https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your-ngrok-authtoken-here

# Pick anything. The ClickHouse container will create this user on first boot.
CLICKHOUSE_USER=estuary

# Generate with: openssl rand -base64 18 | tr '+/' '-_' | tr -d '='
CLICKHOUSE_PASSWORD=replace-me-with-a-strong-password

# Target database (created automatically by the container)
CLICKHOUSE_DB=demo
